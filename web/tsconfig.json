{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "strict": true,
    "baseUrl": "..",
    "paths": {
      "@renderer/*": ["./src/renderer/src/*"],
      "@main/*":     ["./src/main/*"]
    }
  },
  "include": [
    "src/**/*",
    "../src/renderer/src/**/*",
    "../src/main/tulgu.ts",
    "../src/preload/index.d.ts"
  ]
}
